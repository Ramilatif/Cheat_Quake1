{
  "target": {
    "module": "ioquake3.x86_64.exe",
    "platform": "windows-x86_64",
    "module_base_default": "0x0000000000400000",
    "module_size_observed_kib": 28960,
    "cgame_mode": "qvm",
    "notes": [
      "ioquake3 master build, native engine + cgame.qvm interpreter (no cgamex86_64.dll observed in the module list).",
      "Engine globals (clientActive_t cl, struct cls...) live in the .bss of the .exe at fixed RVAs.",
      "Cgame globals (cg_t cg, cg_entities[...]) live in the QVM heap — addresses are runtime-dynamic and must be located by signature scan, not hardcoded."
    ]
  },

  "engine_rvas": {
    "_comment": "RVAs are relative to the .exe module base. Static across runs as long as the engine binary isn't rebuilt.",
    "cl_snap_ps_stat_health": {
      "rva": "0x7B40B8",
      "type": "i32",
      "description": "cl.snap.ps.stats[STAT_HEALTH] — engine-side copy of the local player HP. Matches the HUD in real time.",
      "found_on": "2026-04-20",
      "found_via": "Cheat Engine: scan 4 Bytes exact value, narrowed by taking damage, confirmed by watching value track the HUD."
    }
  },

  "runtime_addresses": {
    "_comment": "Heap-resident structures. Addresses change per run; recover via signature scan. Documented here for reference, not as constants.",
    "cg_activeSnapshots": {
      "scanner": "memory --bin dump-snapshot",
      "signature": "Two SnapshotHeader candidates separated by exactly sizeof(snapshot_t) = 53772 bytes.",
      "observed_window": "0x0000000005000000..0x0000000009000000",
      "session_example_2026_06_02": [
        "0x00000000067FBE88",
        "0x0000000006809094"
      ]
    },
    "parseEntities_buffer": {
      "scanner": "memory --bin scan-entities",
      "signature": "208-byte stride contiguous block, ~1.6 MiB (8192 entityState_t entries).",
      "note": "Lives inside cg.activeSnapshots[N].entities[] — not the engine's cl.parseEntities[] (which would be in the .exe .bss)."
    }
  },

